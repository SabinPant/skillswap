########################################
# APP
########################################
APP_NAME=SkillSwap
APP_ENV=local
APP_KEY=                          # generate with: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

########################################
# DATABASE (PostgreSQL)
########################################
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=skillswap
DB_USERNAME=skillswap
DB_PASSWORD=skillswap_password

########################################
# REDIS (cache, rate limiting, queue, token storage)
########################################
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

########################################
# SANCTUM (auth)
########################################
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

########################################
# CORS
########################################
FRONTEND_URL=http://localhost:3000     # used to lock CORS to the known client origin

########################################
# MAIL (Mailhog local / Resend production)
########################################
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@skillswap.test
MAIL_FROM_NAME="${APP_NAME}"

# Production only — leave blank locally
RESEND_API_KEY=

########################################
# CLOUDINARY (avatar file storage)
########################################
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=                    # optional single-string alternative to the three above

########################################
# LARAVEL REVERB (real-time WebSockets)
########################################
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

BROADCAST_CONNECTION=reverb

########################################
# SKILLSWAP APP CONFIG (config/skillswap.php)
# App refuses to boot without these in non-local environments.
########################################
SKILL_REQUEST_EXPIRY_HOURS=72
SESSION_REMINDER_HOURS_BEFORE=24
MAX_ACTIVE_REQUESTS_PER_USER=20
AVATAR_MAX_SIZE_KB=2048
RATING_CACHE_TTL_MINUTES=60

########################################
# RATE LIMITS (requests per window — see Rate Limits section in PLAN.md)
# Exposed as env vars so limits can be tuned per environment without a code change.
########################################
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15

RATE_LIMIT_REGISTER_ATTEMPTS=3
RATE_LIMIT_REGISTER_WINDOW_MINUTES=60

RATE_LIMIT_FORGOT_PASSWORD_ATTEMPTS=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MINUTES=60

RATE_LIMIT_RESEND_VERIFICATION_ATTEMPTS=3
RATE_LIMIT_RESEND_VERIFICATION_WINDOW_MINUTES=60

RATE_LIMIT_SKILL_REQUEST_ATTEMPTS=10
RATE_LIMIT_SKILL_REQUEST_WINDOW_MINUTES=1

RATE_LIMIT_REVIEW_ATTEMPTS=10
RATE_LIMIT_REVIEW_WINDOW_MINUTES=1

RATE_LIMIT_AVATAR_UPLOAD_ATTEMPTS=5
RATE_LIMIT_AVATAR_UPLOAD_WINDOW_MINUTES=60

RATE_LIMIT_DEFAULT_ATTEMPTS=100
RATE_LIMIT_DEFAULT_WINDOW_MINUTES=1

########################################
# LOGGING
########################################
LOG_CHANNEL=stack
LOG_LEVEL=debug
