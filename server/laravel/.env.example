APP_NAME=SkillSwap
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=skillswap
DB_USERNAME=skillswap
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

SANCTUM_STATEFUL_DOMAINS=localhost:3000
FRONTEND_URL=http://localhost:3000

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@skillswap.test"
MAIL_FROM_NAME="${APP_NAME}"

# Production only — leave blank locally
RESEND_API_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

########################################
# SKILLSWAP APP CONFIG (config/skillswap.php)
# App refuses to boot without these in non-local environments.
########################################
SKILL_REQUEST_EXPIRY_HOURS=72
SESSION_REMINDER_HOURS_BEFORE=24
MAX_ACTIVE_REQUESTS_PER_USER=20
AVATAR_MAX_SIZE_KB=2048
CHAT_ATTACHMENT_MAX_SIZE_KB=8192
RATING_CACHE_TTL_MINUTES=60

# Rate limiting (config/skillswap.php rate_limits section)
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_DECAY_MINUTES=15
RATE_LIMIT_REGISTER_MAX_ATTEMPTS=3
RATE_LIMIT_REGISTER_DECAY_MINUTES=60
RATE_LIMIT_FORGOT_PASSWORD_MAX_ATTEMPTS=3
RATE_LIMIT_FORGOT_PASSWORD_DECAY_MINUTES=60
RATE_LIMIT_RESEND_VERIFICATION_MAX_ATTEMPTS=3
RATE_LIMIT_RESEND_VERIFICATION_DECAY_MINUTES=60
RATE_LIMIT_SKILL_REQUEST_MAX_ATTEMPTS=10
RATE_LIMIT_SKILL_REQUEST_DECAY_MINUTES=1
RATE_LIMIT_REVIEW_MAX_ATTEMPTS=10
RATE_LIMIT_REVIEW_DECAY_MINUTES=1
RATE_LIMIT_CHAT_MESSAGE_MAX_ATTEMPTS=30
RATE_LIMIT_CHAT_MESSAGE_DECAY_MINUTES=1
RATE_LIMIT_AVATAR_UPLOAD_MAX_ATTEMPTS=5
RATE_LIMIT_AVATAR_UPLOAD_DECAY_MINUTES=60
RATE_LIMIT_DEFAULT_MAX_ATTEMPTS=100
RATE_LIMIT_DEFAULT_DECAY_MINUTES=1
